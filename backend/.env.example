PORT=3001
JWT_SECRET=tu-jwt-secret-aqui-minimo-32-caracteres-random
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Correo (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password-aqui
SISTEMAS_EMAIL=tu-email@gmail.com

# ── Credenciales iniciales ─────────────────────────────────────────────────────
MOCK_PASSWORD_SUCURSALES=3787821528
MOCK_PASSWORD_ADMIN=admin123
MOCK_PASSWORD_SOPORTE=sop123
MOCK_PASSWORD_USUARIOS=123456

# ── Tokens JWT ────────────────────────────────────────────────────────────────
JWT_EXPIRES_SISTEMAS=8h
JWT_EXPIRES_SUCURSAL=8h

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_GENERAL=200
RATE_LIMIT_LOGIN=10
RATE_LIMIT_TICKETS=5

# ── SLA (horas) ───────────────────────────────────────────────────────────────
SLA_AUTO_URGENTE_HOURS=8
SLA_WARN_HOURS=4

